<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Data</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 30px;
    }

    h1, h2 {
      color: #222;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 30px;
    }

    table, th, td {
      border: 1px solid #ccc;
    }

    th, td {
      padding: 10px;
      text-align: left;
    }

    th {
      background-color: #f4f4f4;
    }

    .empty {
      color: rgb(255, 255, 255);
      margin-bottom: 20px;
    }
  </style>
</head>
<body>
  <h1>All Project Data</h1>

  <h2>Users</h2>
  <% if (users.length === 0) { %>
    <p class="empty">No users found</p>
  <% } else { %>
    <table>
      <thead>
        <tr>
          <th>Username</th>
          <th>First Name</th>
          <th>Last Name</th>
          <th>Role</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach((user) => { %>
          <tr>
            <td><%= user.username %></td>
            <td><%= user.firstName %></td>
            <td><%= user.lastName %></td>
            <td><%= user.role %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>

  <h2>Books</h2>
  <% if (books.length === 0) { %>
    <p class="empty">No books found</p>
  <% } else { %>
    <table>
      <thead>
        <tr>
          <th>Title</th>
          <th>Status</th>
          <th>Tags</th>
          <th>Owner Username</th>
          <th>Owner Name</th>
        </tr>
      </thead>
      <tbody>
        <% books.forEach((book) => { %>
          <tr>
            <td><%= book.title %></td>
            <td><%= book.status %></td>
            <td><%= book.tags.join(", ") %></td>
            <td><%= book.userId?.username || "Unknown" %></td>
            <td>
              <%= book.userId ? `${book.userId.firstName} ${book.userId.lastName}` : "Unknown" %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</body>
</html>